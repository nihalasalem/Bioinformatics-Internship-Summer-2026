# ============================================
# Correlation Analysis: Cortex Size vs Neurons
# ============================================

# Load required package
library(ggplot2)



# --------------------------------------------
# Scientific question
# Do species with larger cortices have more neurons?
# --------------------------------------------

# --------------------------------------------
# Pearson correlation test
# --------------------------------------------

cor.test(
  species_brainmass_neurons$cortex_mass_g,
  species_brainmass_neurons$Neurons,
  method = "pearson"
)

# --------------------------------------------
# Visualize the relationship
# --------------------------------------------

ggplot(
  species_brainmass_neurons,
  aes(x = cortex_mass_g, y = Neurons)
) +
  geom_point(size = 2, alpha = 0.8) +
  geom_smooth(method = "lm", se = FALSE, color = "red") +
  scale_x_log10() +
  scale_y_log10() +
  labs(
    title = "Cortex Mass vs Cortical Neuron Number Across Species",
    x = "Cortex mass (g)",
    y = "Total cortical neurons"
  ) +
  theme_minimal()

