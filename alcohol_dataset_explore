#the goal here is to clean up the metadatafile, transpose it, remove redundant words
#read the dataset
GSE253155_series_matrix <- read_csv("/cloud/project/Summer_2026/Datasets/Human_AUD_GSE253155/GSE253155_series_matrix.csv")
# Transpose the metadata
meta_raw<-GSE253155_series_matrix
meta_raw_t<-t(meta_raw)
colnames(meta_raw_t)<-meta_raw_t[1,]
meta_raw_t<-meta_raw_t[-1,]
#subset the meaningful columns
meta_subset<-meta_raw_t[,c(7,10,11,13,14)]
# 👉 Rename columns so they are meaningful
# (Age, Sex, Tissue, AUD_Status, Depression, etc.)
#rename the columns
colnames(meta_subset)<-c("brain_region","alcohol_status","sex","depression","smoking")
#Clean text fields
# Some entries look like:
# "Age; 45"
# We only want what comes AFTER the semicolon.
meta_subset<-sub(".*:", "", meta_subset)
meta_subset<-as.data.frame(meta_subset)
